# Example environment file for bot6rangos.
# Copy to .env and fill real Telegram/exchange values before enabling services.

TZ=America/Argentina/Buenos_Aires
SYMBOL=ETHUSDT.P
STREAM_INTERVAL=30m
CHANNEL_INTERVAL=30m

# Watcher/trading
WATCHER_ENABLE_TRADING=true
WATCHER_ACCOUNTS_FILE=trading/accounts/oci_accounts.yaml
WATCHER_TRADING_DRY_RUN=true
WATCHER_TRADING_USER=
WATCHER_TRADING_EXCHANGE=
WATCHER_TRADING_MIN_PRICE=0
WATCHER_ORDER_ID_PREFIX=B6R
WATCHER_SERVICE_NAME=bot6rangos-watcher.service
HEARTBEAT_SERVICES="bot6rangos-watcher.service;bot6rangos-heartbeat.service;bot6rangos-telegram.service"
WATCHER_POSITION_RETRY_COUNT=7
WATCHER_POSITION_RETRY_DELAY=0.5
WATCHER_THRESHOLDS_CLEAR_ON_STARTUP=false
WATCHER_THRESHOLDS_REBUILD_ON_STARTUP=true
WATCHER_ACCOUNTS_AUTO_RELOAD=true
WATCHER_DISABLED_AUTO_CLOSE=false
WATCHER_DISABLED_CLOSE_POLL_SECONDS=30
WATCHER_CLOSE_OPPOSITE_TIMEOUT_SECONDS=10
WATCHER_CLOSE_OPPOSITE_POLL_SECONDS=0.5

# Strategy: stable SMA115 + prev10 + distance filter
BOT6_STRATEGY_MODE=sma115_stable
ALERT_ENABLE_BOLLINGER_SIGNALS=true
ALERT_STREAM_BARS=5000
ALERT_POLL_SECONDS=5
ALERT_MAX_SEEN=500
SMA_STABLE_LEN=115
SMA_STABLE_PREV_AVG_BARS=10
SMA_STABLE_MAX_DISTANCE_PCT=0.01
SMA_STABLE_TAKE_PROFIT_PCT=0.08
SMA_STABLE_PENDING_SL_PCT=0.02
STRAT_STOP_LOSS_PCT=0.05

# Legacy Range3 + Bollinger strategy
RANGE_LOOKBACK_BARS=200
RANGE_PCT_UPPER=25
RANGE_PCT_MIDDLE=50
RANGE_PCT_LOWER=25
RANGE_BB_SIGNAL_TYPE="Cruce de cierre"
RANGE_CLASSIFY_WITH=Mecha
RANGE_NEW_EXTREME_BARS=3
RANGE_PENDING_ORDER_TYPE="Stop en banda"
RANGE_PENDING_STATE_PATH=backtest/backtestTR/range3_pending_order.json
RANGE_TRAILING_STEP_PCT=0.01
RANGE_PROFIT_LOCK_TRIGGER_PCT=0.03
RANGE_PROFIT_LOCK_SL_PCT=0.005
RANGE_FLIP_STOP_LOSS_PCT=0.02
RANGE_FLIP_TAKE_PROFIT_PCT=0.02

# Signal worker
WATCHER_STARTUP_TEST_ALERT=true
THRESHOLD_POLL_SECONDS=1
ALERT_SIGNAL_WORKER_ENABLED=true
ALERT_SIGNAL_WORKER_STALE_SECONDS=30
ALERT_SIGNAL_WORKER_RESTART_BACKOFF_SECONDS=3
ALERT_SIGNAL_WORKER_QUEUE_MAX=200
SIGNAL_BUS_EXPORT_ENABLED=false
SIGNAL_BUS_EXPORT_FILE=/home/ubuntu/shared/bot6rangos_signals.jsonl
SIGNAL_BUS_EXPORT_TYPES=range3_signal,range3_pending_fill

# Telegram
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_CHAT_IDS=123456789

# Exchange config
BINANCE_MIN_NOTIONAL=20
BINANCE_UM_BASE_URL=https://fapi.binance.com
BINANCE_RECV_WINDOW_MS=20000
BINANCE_HTTP_TIMEOUT=10
BINANCE_TIMESTAMP_RETRY_COUNT=2
BINANCE_TIMESTAMP_RETRY_DELAY=0.25
BINANCE_KLINES_HTTP_TIMEOUT=8
BINANCE_KLINES_RETRY_COUNT=3
BINANCE_KLINES_RETRY_BASE_DELAY=0.4
BINANCE_KLINES_RETRY_MAX_DELAY=3.0
WATCHER_MARK_PRICE_RETRY_COUNT=2
WATCHER_MARK_PRICE_RETRY_DELAY=0.25

# Binance credentials (examples only)
DIEGO_BINANCE_LIVE_API_KEY=YOUR_KEY
DIEGO_BINANCE_LIVE_API_SECRET=YOUR_SECRET
BRUNO_BINANCE_LIVE_API_KEY=YOUR_KEY
BRUNO_BINANCE_LIVE_API_SECRET=YOUR_SECRET

# Bybit credentials (examples only)
BYBIT_DOMAIN=api.bybit.com
BYBIT_DOMAIN_TESTNET=api-testnet.bybit.com
BYBIT_RECV_WINDOW_MS=20000
BYBIT_HTTP_TIMEOUT=10
BYBIT_TIMESTAMP_RETRY_COUNT=2
BYBIT_TIMESTAMP_RETRY_DELAY=0.25
EXCHANGE_TIME_WARN_DRIFT_MS=1500
DIEGO_BYBIT_LIVE_API_KEY=YOUR_KEY
DIEGO_BYBIT_LIVE_API_SECRET=YOUR_SECRET
BRUNO_BYBIT_TESTNET_API_KEY=YOUR_KEY
BRUNO_BYBIT_TESTNET_API_SECRET=YOUR_SECRET

# Retry/monitor guards
WATCHER_POSITION_GUARD_RETRY_ENABLED=true
WATCHER_POSITION_GUARD_RETRY_BASE_SECONDS=1
WATCHER_POSITION_GUARD_RETRY_MAX_SECONDS=60
WATCHER_POSITION_GUARD_RETRY_JITTER_SECONDS=0.3
WATCHER_POSITION_GUARD_RETRY_TTL_SECONDS=21600
WATCHER_POSITION_GUARD_WORKER_POLL_SECONDS=1
WATCHER_POSITION_GUARD_QUEUE_FILE=backtest/backtestTR/pending_trade_retries.json
WATCHER_POSITION_MONITOR_ALERTS=true
WATCHER_POSITION_MONITOR_COOLDOWN_SECONDS=300
WATCHER_POSITION_MONITOR_UNKNOWN_ALERT_EVERY=5
WATCHER_POSITION_MONITOR_POLL_SECONDS=10
WATCHER_POSITION_MONITOR_REQUIRE_OPEN=true
WATCHER_POSITION_MONITOR_FLAT_ALERT_SECONDS=90

# Ledgers
BALANCE_LEDGER_PATH=backtest/backtestTR/balance_ledger.jsonl
BALANCE_BACKFILL_STATE_PATH=backtest/backtestTR/balance_backfill_state.json
BALANCE_LEDGER_SOURCE=live
TRADES_TABLE_LEDGER_PATH=backtest/backtestTR/trades_table_ledger.jsonl
OPEN_TRADE_STATE_PATH=backtest/backtestTR/open_trade_state.json
PENDING_EXECUTION_RESOLUTIONS_PATH=backtest/backtestTR/pending_execution_resolutions.json
TRADES_FILL_RESOLVE_WAIT_SECONDS=45
TRADES_FILL_RESOLVE_POLL_SECONDS=1
TRADES_FILL_RESOLVE_TTL_SECONDS=86400
TRADES_FILL_RESOLVE_WORKER_POLL_SECONDS=3
TRADES_FILL_RESOLVE_ATTEMPT_SECONDS=8
TRADES_EXPORT_DEFAULT_SOURCE=live
